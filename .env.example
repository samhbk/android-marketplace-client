# Local environment template (documentation only)
#
# This Android app does not load a .env file at runtime. Use these values as reference
# when configuring local.properties or build.gradle.kts.
#
# Copy: cp .env.example .env
# Do not commit .env — it is gitignored.

# REST API base URL (no trailing slash)
# Default in build.gradle.kts: http://10.0.2.2:8080 (emulator → host)
# Override via local.properties: API_BASE_URL=http://10.0.2.2:8080
API_BASE_URL=http://10.0.2.2:8080

# Optional: demo credentials for your local backend (never use production passwords)
# DEMO_API_EMAIL=demo@example.com
# DEMO_API_PASSWORD=
